# ============================================
# AgentVerse — AI Agent Dashboard
# Environment Configuration
# ============================================
#
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Then edit .env with your keys (its gitignored so secrets stay safe).
# ============================================

# --- Supabase (Multi-User & Persistent Storage) ---
# Required for: cross-device sync, multi-user auth
# Get started: https://supabase.com
#
# 1. Create a new project at supabase.com
# 2. Go to Project Settings -> API
# 3. Copy your Project URL and anon/public key
# 4. Run the SQL from src/data/schema.sql in the SQL Editor
#
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- NVIDIA AI (Recommended for API access) ---
# Get a free key: https://build.nvidia.com/
# Uses: meta/llama-3.1-8b-instruct (default agent model)
# NOTE: Only VITE_NVIDIA_API_KEY works via environment variable.
# For OpenAI, Anthropic, or Google AI keys, use the UI instead:
#   Open the dashboard - Integrations -> API Keys -> Add API Key
#
VITE_NVIDIA_API_KEY=nvapi-your-key-here
